# ============================================================
# .gitignore — AI Finance Incidents Project
# ============================================================

# ── Ambiente virtual ────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env
.env.local
.env.production
.env.staging

# ── Segredos e chaves ───────────────────────────────────────
*.key
*.pem
*.p12
secrets.toml
.streamlit/secrets.toml

# ── Dados sensíveis / grandes ───────────────────────────────
*.csv
*.db
*.sqlite
*.sqlite3
database/
!database/.gitkeep

# ── Modelos ML serializados ─────────────────────────────────
models/
!models/.gitkeep

# ── Cache Jupyter ───────────────────────────────────────────
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── OS ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# ── IDEs ────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Logs ────────────────────────────────────────────────────
*.log
logs/

# ── Streamlit ───────────────────────────────────────────────
.streamlit/secrets.toml

# ── Pytest / coverage ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
